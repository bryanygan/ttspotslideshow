# Copy this file to ".env" and fill in the values from your Spotify Developer app.
# Get these at https://developer.spotify.com/dashboard (create an app first).

SPOTIPY_CLIENT_ID=your_client_id_here
SPOTIPY_CLIENT_SECRET=your_client_secret_here

# Must EXACTLY match a Redirect URI you add in the app settings.
# Spotify requires the loopback IP (127.0.0.1), not "localhost".
SPOTIPY_REDIRECT_URI=http://127.0.0.1:8888/callback

# --- Last.fm (for genre enrichment fallback + history import) ---
# Get an API key at https://www.last.fm/api/account/create
LAST_FM_API_KEY=your_lastfm_api_key_here
LAST_FM_SHARED_SECRET=your_lastfm_shared_secret_here
# Optional: override the auto-detected newest data/scrobbles-*.xml export
# LASTFM_EXPORT_PATH=
